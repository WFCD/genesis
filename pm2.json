{
  "apps": [
    {
      "name": "genesis-test",
      "script": "bot/main.ts",
      "exec_interpreter": "node",
      "node_args": "--import tsx/esm",
      "watch": ["genesis.json"],
      "log_date_format": "YYYY-MM-DD HH:mm Z",
      "env": {
        "SCOPE": "BOT",
        "TOKEN": "<discord bot token>",
        "RAVEN_URL": "<raven logging URL>",
        "PREFIX": "++",
        "DISCORD_CARBON_TOKEN": "Not used yet",
        "DISCORD_BOTS_WEB_USER": "Not used yet",
        "DISCORD_BOTS_WEB_TOKEN": "Not used yet",
        "OWNER": "<owner id for checking permissions>",
        "CLIENT_ID": "<discord application id>",
        "SHARDS": 1,
        "LOCAL_SHARDS": 1,
        "SHARD_OFFSET": 0,
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": 3306,
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "password",
        "MYSQL_DB": "genesis",
        "LOG_LEVEL": "ERROR",
        "WORLDSTATE_TIMEOUT": 60000,
        "INVITE_URL": "https://github.com/wfcd/genesis",
        "CONTROL_WH_ID": "webhook id for control channel goes here",
        "CONTROL_WH_TOKEN": "webhook token for control channel goes here",
        "NODE_ENV": "development",
        "GAMES": "UTIL,WARFRAME,ROOMS,CUST_CMDS,BOT_MGMT,CMD_MGMT,FUN",
        "TWITCH_CLIENT_ID": "--REQUIRED--",
        "TWITCH_USER_LOGIN": "warframe",
        "TWITCH_POLL_INTERVAL_MS": 10000
      }
    }
  ]
}
