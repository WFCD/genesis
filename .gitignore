# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules
jspm_packages

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Local runtime config (not committed)
genesis.json
worker.json
worker.dev.json
.idea/
mypm2.json

# giveaways flatfile
**/giveaways.json

# Commands manifest
commands.json

# Compiled TypeScript (tsup prod bundle + tsc artifacts)
dist/
*.tsbuildinfo
**/*.js.map

# Source is TypeScript — ignore legacy/accidental JS in source trees
packages/bot/**/*.js
packages/worker/**/*.js
packages/shared/**/*.js
spec/**/*.js

# Local env (never commit secrets)
.env.local
.env.local
packages/web/.env.local
packages/web/.env.local.local
!packages/*/.env*.example

.cache/
.run
.eslintcache

# Web (Next.js)
**/.next/
packages/web/out