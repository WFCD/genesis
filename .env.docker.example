# Copy to `.env.docker` and fill in values for local Docker Compose testing.
# Database connection vars below are overridden by docker-compose (MariaDB service).

# --- Required for live Discord bot smoke ---
TOKEN=
OWNER=
CLIENT_ID=

# --- Shared ---
PREFIX=++
LOG_LEVEL=INFO
NODE_ENV=development
INVITE_URL=https://github.com/wfcd/genesis
CONTROL_GUILD_ID=
CONTROL_WH_ID=
CONTROL_WH_TOKEN=
SHARDS=1
LOCAL_SHARDS=1
SHARD_OFFSET=0
WORLDSTATE_TIMEOUT=60000

# Warframe API base URL (defaults to https://api.warframestat.us when unset)
# Prefix with _ to disable a local override, e.g. _API_BASE_PATH=http://localhost:56431
# API_BASE_PATH=http://localhost:56431

# Static catalog disk cache (weapons/warframes/mods/items) via flat-cache.
# Files land in .cache/ as api-catalog (same store dir as worker/twitch caches).
# API_CACHE_TTL_MS=86400000
# API_CACHE_DIR=.cache

# --- Bot profile (SCOPE=BOT, set in compose) ---
GAMES=UTIL,WARFRAME,ROOMS,CUST_CMDS,BOT_MGMT,CMD_MGMT,FUN

# --- Worker profile (SCOPE=WORKER, enable with: docker compose --profile worker up) ---
# GAMES=WARFRAME,UTIL,CUST_CMDS,RSS,TWITCH,BARO
# PLATFORMS=pc
# LOCALES=en
# DEF_USER=Genesis
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=

# --- Optional ---
# BUG_WH_ID=
# BUG_WH_TOKEN=
# RAVEN_URL=
# TWITCH_USER_LOGIN=warframe

# --- Database (MariaDB / mysql2 driver; env names stay MYSQL_*) ---
# Docker Compose overrides these to reach the mariadb service (genesis/genesis).
# For npm run dev against compose MariaDB on localhost:3306, use genesis/genesis — not PM2 creds.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=genesis
MYSQL_PASSWORD=genesis
MYSQL_DB=genesis
