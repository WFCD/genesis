{
  "name": "@genesis/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#shared/*": "@genesis/shared/*"
  },
  "scripts": {
    "build": "next build --webpack",
    "check": "npm run typecheck && npm run check:client-secrets",
    "check:client-secrets": "node scripts/check-client-bundle.mjs",
    "dev": "next dev --webpack --port 3131 --hostname localhost",
    "start": "next start --port 3131",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@genesis/shared": "*",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@tailwindcss/postcss": "^4.1.11",
    "clsx": "^2.1.1",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.29",
    "postcss": "8.5.15",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.1.11"
  }
}
