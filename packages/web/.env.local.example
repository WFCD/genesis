# Copy to `web/.env.local` for local Next.js dev (`cd web && npm run dev`).
# Repo-root `.env.local` is also loaded when web-local vars are unset (TOKEN, MYSQL_*, etc.).

AUTH_SECRET=
# Must match the URL you open in the browser (not 127.0.0.1 or LAN IP unless you change this too).
# Discord OAuth redirect: http://localhost:3131/api/auth/callback/discord
AUTH_URL=http://localhost:3131
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Discord REST for channel/role lists (falls back to TOKEN from .env.local)
BOT_TOKEN=

SCOPE=web
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=genesis
MYSQL_PASSWORD=genesis
MYSQL_DB=genesis

PORT=3131

# Optional dashboard panels (default off until bot/worker support lands)
# NEXT_PUBLIC_FEATURE_CHANNEL_PERMISSIONS=true
# NEXT_PUBLIC_FEATURE_GUILD_WELCOME=true
